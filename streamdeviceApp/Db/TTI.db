    field(DESC, "Voltage Step Size")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setDeltaV $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(DRVH, "1.0")
    field(DRVL, "0.0")
    field(VAL,  "0.1")
}

record(ao, "$(P)$(R)DeltaI_Set") {
    field(DESC, "Current Step Size")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setDeltaI $(PORT)")
    field(EGU,  "A")
    field(PREC, "3")
    field(DRVH, "1.0")
    field(DRVL, "0.0")
    field(VAL,  "0.01")
}

