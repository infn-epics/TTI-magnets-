##############################################################################
# OVP (Over Voltage Protection)
##############################################################################

record(ao, "$(P)$(R)OVP_Set") {
    field(DESC, "OVP Threshold")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setOVP $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(DRVH, "40.0")   # Max per TSX3510P (modificare per TSX1820P: 25.0)
    field(DRVL, "1.0")
    field(HOPR, "40.0")
    field(LOPR, "1.0")
    field(PINI, "NO")
    field(FLNK, "$(P)$(R)OVP:Set:Rbv")
}

record(ai, "$(P)$(R)OVP_Set_Rbv") {
    field(DESC, "OVP Threshold Readback")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getOVP $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(SCAN, "Passive")
}

##############################################################################
# OUTPUT ON/OFF CONTROL
##############################################################################

record(bo, "$(P)$(R)Pwr") {
    field(DESC, "Output On/Off")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setOutputState $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(PINI, "NO")
    field(FLNK, "$(P)$(R)Pwr:Rbv")
}

record(bi, "$(P)$(R)Pwr_Rbv") {
    field(DESC, "Output State")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getOutputState $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(SCAN, "1 second")
}

##############################################################################
# OPERATING MODE (CV/CC)
##############################################################################

# Limit Status Register (bit 0 = CC, bit 1 = CV, bit 2 = TRIP)
record(longin, "$(P)$(R)LimitStatus") {
    field(DESC, "Limit Status Register")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getLimitStatus $(PORT)")
    field(SCAN, "1 second")
    field(FLNK, "$(P)$(R)CalcMode")
}

# Calcola modo operativo
record(calcout, "$(P)$(R)CalcMode") {
    field(DESC, "Calculate Operating Mode")
    field(INPA, "$(P)$(R)LimitStatus")
    field(CALC, "A&3")  # Maschera bit 0 e 1
    field(OUT,  "$(P)$(R)Mode PP")
    field(OOPT, "Every Time")
}

# Operating Mode Display
record(mbbi, "$(P)$(R)Mode") {
    field(DESC, "Operating Mode")
    field(INP,  "$(P)$(R)CalcMode")
    field(ZRVL, "0")
    field(ZRST, "Unknown")
    field(ZRSV, "MINOR")
    field(ONVL, "1")
    field(ONST, "CC")      # Constant Current
    field(ONSV, "NO_ALARM")
    field(TWVL, "2")
    field(TWST, "CV")      # Constant Voltage
    field(TWSV, "NO_ALARM")
    field(THVL, "3")
    field(THST, "Unstable")
    field(THSV, "MAJOR")
}

# Trip Status (bit 2)
record(calcout, "$(P)$(R)CalcTrip") {
    field(DESC, "Calculate Trip Status")
    field(INPA, "$(P)$(R)LimitStatus")
    field(CALC, "(A&4)>>2")  # Estrae bit 2
    field(OUT,  "$(P)$(R)Trip PP")
    field(OOPT, "Every Time")
}

record(bi, "$(P)$(R)Trip") {
    field(DESC, "Trip Status")
    field(INP,  "$(P)$(R)CalcTrip")
    field(ZNAM, "OK")
    field(ONAM, "TRIPPED")
    field(ZSV,  "NO_ALARM")
    field(OSV,  "MAJOR")
}

