# CONNECTION STATUS
##############################################################################

record(bi, "$(P)$(R)Connected") {
    field(DESC, "Connection Status")
    field(INP,  "$(P)$(R)Volt:Rbv.SEVR")
    field(ZNAM, "Connected")
    field(ONAM, "Disconnected")
    field(ZSV,  "NO_ALARM")
