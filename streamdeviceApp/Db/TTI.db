##############################################################################

# Current Limit Setpoint
record(ao, "$(P)$(R)Curr_Set") {
    field(DESC, "Current Limit Setpoint")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setCurrent $(PORT)")
    field(EGU,  "A")
    field(PREC, "3")
    field(DRVH, "10.2")   # Max per TSX3510P (modificare per TSX1820P: 20.2)
    field(DRVL, "0.01")
    field(HOPR, "10.2")
    field(LOPR, "0.01")
    field(PINI, "NO")
    field(FLNK, "$(P)$(R)Curr:Set:Rbv")
}

