
# Voltage Setpoint
record(ao, "$(P)$(R)Volt_Set") {
    field(DESC, "Voltage Setpoint")
    field(DTYP, "stream")
    field(OUT,  "@TSX.proto setVoltage $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(DRVH, "35.3")   # Max per TSX3510P (modificare per TSX1820P: 18.15)
    field(DRVL, "0")
    field(HOPR, "35.3")
    field(LOPR, "0")
    field(PINI, "NO")
    field(FLNK, "$(P)$(R)Volt:Set:Rbv")
}

# Voltage Setpoint Readback
record(ai, "$(P)$(R)Volt_Set_Rbv") {
    field(DESC, "Voltage Setpoint Readback")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getVoltageSet $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(SCAN, "Passive")
}

# Voltage Output Readback (Actual)
record(ai, "$(P)$(R)Volt_Rbv") {
    field(DESC, "Voltage Output")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getVoltageRbv $(PORT)")
    field(EGU,  "V")
    field(PREC, "3")
    field(SCAN, "1 second")  # Polling ogni secondo
    field(FLNK, "$(P)$(R)CalcMode")
}

