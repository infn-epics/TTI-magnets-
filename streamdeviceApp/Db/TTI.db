record(ai, "$(P)$(R)Curr_Set_Rbv") {
    field(DESC, "Current Limit Readback")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getCurrentSet $(PORT)")
    field(EGU,  "A")
    field(PREC, "3")
    field(SCAN, "Passive")
}

# Current Output Readback (Actual)
record(ai, "$(P)$(R)Curr_Rbv") {
    field(DESC, "Current Output")
    field(DTYP, "stream")
    field(INP,  "@TSX.proto getCurrentRbv $(PORT)")
    field(EGU,  "A")
    field(PREC, "3")
    field(SCAN, "1 second")
}

