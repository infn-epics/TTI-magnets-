# controllo startramp 
record(bo, "$(P)$(R)Output") {
    field(DTYP, "stream")
    field(OUT, "@TTI.proto setOutput $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(DESC, "Output ON/OFF control")
}

record(calcout, "$(P)$(R)Autoramp") {
    field(DESC, "Auto-enable output when V and I set")
    # field(INPA, "$(P)$(R)VOLTAGE_SP")
    # &&(B>0)
    field(INPA, "$(P)$(R)CURRENT_SP")
    field(CALC, "(A>0)?1:0")
    field(OUT, "$(P)$(R)Output PP")
    field(OOPT, "Every Time")
    field(DOPT, "Use CALC")
    field(ODLY, "0.5")
}

